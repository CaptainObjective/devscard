---
import Fonts from '@/components/fonts.astro';
import type { MetaConfig } from '@/types/config/meta-config.types';
import type { Sections } from '@/types/data';
import Favicons from './favicons.generated.astro';
import InitialHash from './initial-hash.astro';
import InitialTheme from './initial-theme.astro';
import Meta from './meta.astro';

interface Props {
  meta: MetaConfig;
  sections: Sections;
}

const { meta, sections } = Astro.props;
---

<head>
  <Meta meta={meta} />
  <Favicons />
  <InitialHash sections={sections} />
  <InitialTheme />
  <Fonts />
  <script defer src="https://cloud.umami.is/script.js" data-website-id="950469a7-3868-4e6e-bcca-fa1a04724221"></script>
</head>
